## File Map — Create These Files First

```
server/src/
  index.ts                # Express app entry
  db/
    client.ts             # Turso client singleton
    schema.sql            # table definitions
    seed.ts               # dev seed
  routes/
    chat.ts               # POST /api/v1/chat
    session.ts            # POST /api/v1/session
    dashboard.ts          # GET /api/v1/dashboard/:sessionId
  services/
    mistral.ts            # all Mistral API calls
    moderation.ts         # Mistral Moderation parallel checker
    crisis.ts             # crisis handler (DB log + email)
    toneScorer.ts         # post-conversation scoring
  middleware/
    validate.ts           # Zod validation middleware factory
    rateLimit.ts          # basic rate limiter
  config/
    env.ts                # Zod-parsed environment variables

game/src/
  main.ts                 # Phaser game config + boot
  config/
    zones.ts              # character zone rectangles
    characters.ts         # character definitions (name, animal, position, prompt key)
  scenes/
    BootScene.ts          # preload all assets
    VillageScene.ts       # main game world
    ConversationScene.ts  # chat panel (runs in parallel with VillageScene)
    OnboardingScene.ts    # 3-step wizard (or React overlay)
    CrisisScene.ts        # full-screen crisis overlay
  characters/
    CharacterSprite.ts    # base character class
    ProximityDetector.ts  # zone overlap logic
  ui/
    ChatPanel.ts          # Phaser-based chat UI
    SpeechBubble.ts       # proximity prompt bubble
    DayNightOverlay.ts    # time-based tint overlay
  api/
    client.ts             # fetch wrapper for server API
  store/
    session.ts            # localStorage session state

dashboard/src/
  App.tsx
  pages/
    ParentDashboard.tsx
  components/
    WeekSummary.tsx
    CharacterChart.tsx
    ToneBreakdown.tsx
    Suggestion.tsx
  hooks/
    useDashboardData.ts
  api/
    client.ts

shared/src/
  types.ts                # ALL shared types: ChatRequest, ChatResponse, SessionData, etc.
```

